{
  "name": "grinder",
  "version": "0.1.0",
  "description": "Cafe Neurotico GRINDER — The robot barista. Roasts, grinds, and serves your GOG & Epic games — downloading, configuring Proton, and pulling the perfect shot every time.",
  "main": "main.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --linux AppImage",
    "postdist": "D=/home/jose/Games/CNGM; F=GRINDER.AppImage; [ -f $D/$F ] && mv $D/$F $D/GRINDER_old.AppImage; cp dist/$F $D/$F && echo \"Deployed $F to $D\""
  },
  "author": "Shampoo is a Lie",
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.cafeneurotico.grinder",
    "productName": "GRINDER",
    "linux": {
      "target": "AppImage",
      "icon": "assets/icons/grinder_icon.svg",
      "category": "Game"
    },
    "appImage": {
      "artifactName": "GRINDER.AppImage"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "assets/icons/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/bin/linux",
        "to": "assets/bin/linux",
        "filter": ["**/*"]
      }
    ]
  }
}
